{
    "name": "ib-utilities",
    "displayName": "IrishBruse's Utilities",
    "description": "A collection of utilities made by me",
    "icon": "logo.png",
    "repository": {
        "url": "https://github.com/IrishBruse/irishbruse-utilities"
    },
    "publisher": "irishbruse",
    "author": "Ethan Conneely",
    "version": "0.10.0",
    "license": "MIT",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onView:ib-utilities.actionPanel",
        "onView:ib-utilities.gitHelpers"
    ],
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build": "node scripts/generate-codicon-assets.mjs && node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "package": "node esbuild.mjs --production",
        "lint": "eslint src && tsc --noEmit",
        "test": "vitest run",
        "verify": "npm run build && npm run test && npm run lint",
        "package:vsix": "vsce package --out ib-utilities-$(node -p \"require('./package.json').version\").vsix",
        "release": "node scripts/release.mjs",
        "test:watch": "vitest watch",
        "generate:contributes": "node generators/contributes.generator.ts",
        "generate:contributes:watch": "node --watch generators/contributes.generator.ts"
    },
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "IrishBruse Utilities",
            "properties": {
                "ib-utilities.languageIdMappings": {
                    "type": "object",
                    "description": "Map snippet files to known language ID.",
                    "additionalProperties": {
                        "type": "string",
                        "description": "The replacement language ID."
                    },
                    "default": {
                        "node": "typescript",
                        "react": "typescriptreact"
                    }
                },
                "ib-utilities.generatedLanguageMappings": {
                    "type": "object",
                    "description": "On the left is the languageId for the snippet to auto generate on the right is the comma delimited array of languages to build it from.",
                    "additionalProperties": {
                        "type": "string",
                        "description": "The resulting language ID."
                    },
                    "default": {
                        "javascript": "node",
                        "typescript": "node",
                        "typescriptreact": "node,react",
                        "javascriptreact": "node,react"
                    }
                },
                "ib-utilities.actionPanel.actions": {
                    "type": "array",
                    "description": "Actions shown in the Action Panel. Cursor agent prompts use type \"agent\"; VS Code commands use type \"command\".",
                    "items": {
                        "type": "object",
                        "required": [
                            "id",
                            "label",
                            "type"
                        ],
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "Unique action id."
                            },
                            "label": {
                                "type": "string",
                                "description": "Label shown in the panel."
                            },
                            "icon": {
                                "type": "string",
                                "description": "Codicon name without $(), e.g. github."
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "agent",
                                    "command"
                                ],
                                "description": "Action type."
                            },
                            "prompt": {
                                "type": "string",
                                "description": "Agent prompt when type is agent. Supports ${branch}, ${repoRoot}, ${baseBranch}, ${file}, and ${selection}."
                            },
                            "command": {
                                "type": "string",
                                "description": "VS Code command id when type is command."
                            },
                            "args": {
                                "type": "array",
                                "description": "Optional arguments passed to the VS Code command.",
                                "items": {}
                            }
                        }
                    },
                    "default": []
                }
            }
        },
        "customEditors": [
            {
                "viewType": "ib-utilities.mermaidPreview",
                "displayName": "Mermaid Preview",
                "selector": [
                    {
                        "filenamePattern": "*.mmd"
                    },
                    {
                        "filenamePattern": "*.mermaid"
                    }
                ],
                "priority": "default"
            }
        ],
        "languages": [
            {
                "id": "gherkin",
                "aliases": [
                    "Gherkin",
                    "feature",
                    "cucumber"
                ],
                "extensions": [
                    ".feature"
                ],
                "configuration": "./syntaxes/gherkin.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gherkin",
                "scopeName": "text.gherkin.feature",
                "path": "./syntaxes/gherkin.tmLanguage"
            },
            {
                "scopeName": "markdown.gherkin.codeblock",
                "path": "./syntaxes/gherkin.markdown-injection.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.gherkin": "gherkin"
                }
            }
        ],
        "themes": [
            {
                "label": "Empty Dark Theme",
                "uiTheme": "vs-dark",
                "path": "./themes/empty-dark.json"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "snippetContainer",
                    "title": "Snippet Manager",
                    "icon": "media/snippet_icon.svg"
                },
                {
                    "id": "actionPanel",
                    "title": "Actions",
                    "icon": "$(run-all)"
                }
            ]
        },
        "views": {
            "snippetContainer": [
                {
                    "id": "snippetView",
                    "name": "Groups",
                    "icon": "media/snippet_icon.svg"
                }
            ],
            "actionPanel": [
                {
                    "id": "ib-utilities.actionPanel",
                    "name": "Actions",
                    "icon": "$(run-all)",
                    "contextualTitle": "Actions",
                    "visibility": "visible"
                }
            ],
            "scm": [
                {
                    "id": "ib-utilities.gitHelpers",
                    "name": "Git Helpers",
                    "icon": "$(git-branch)",
                    "contextualTitle": "Git Helpers",
                    "visibility": "visible"
                }
            ]
        },
        "commands": [
            {
                "command": "ib-utilities.relativeGoTo",
                "title": "Relative goto",
                "shortTitle": "Relative goto"
            },
            {
                "command": "ib-utilities.openSnippet",
                "title": "Open Snippet",
                "shortTitle": "Open"
            },
            {
                "command": "ib-utilities.showSnippetView",
                "title": "Show Snippet View",
                "shortTitle": "Show Snippet View"
            },
            {
                "command": "ib-utilities.openPR",
                "title": "Open Pull Request",
                "shortTitle": "Open PR",
                "icon": "$(github)"
            },
            {
                "command": "ib-utilities.createDraftPR",
                "title": "Create Draft Pull Request",
                "shortTitle": "Create draft PR",
                "icon": "$(git-pull-request-create)"
            },
            {
                "command": "ib-utilities.markPrReady",
                "title": "Mark Pull Request Ready",
                "shortTitle": "Mark ready",
                "icon": "$(check)"
            },
            {
                "command": "ib-utilities.copyPrUrl",
                "title": "Copy Pull Request URL",
                "shortTitle": "Copy PR URL",
                "icon": "$(copy)"
            },
            {
                "command": "ib-utilities.openFailedJobLog",
                "title": "Open Failed Job Log",
                "shortTitle": "Open failed job log",
                "icon": "$(warning)"
            },
            {
                "command": "ib-utilities.openPrChanges",
                "title": "Open Pull Request Changes",
                "shortTitle": "Open PR changes",
                "icon": "$(git-compare)"
            },
            {
                "command": "ib-utilities.openPrReview",
                "title": "Open Pull Request Review",
                "shortTitle": "Open PR review",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "ib-utilities.refreshSnippetView",
                "title": "Refresh Snippets",
                "shortTitle": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "ib-utilities.addSnippet",
                "title": "Add new snippet",
                "shortTitle": "Add snippet",
                "icon": "$(add)"
            },
            {
                "command": "ib-utilities.editSnippet",
                "title": "Edit snippet",
                "shortTitle": "Edit snippet",
                "icon": "$(edit)"
            },
            {
                "command": "ib-utilities.deleteSnippet",
                "title": "Delete snippet",
                "shortTitle": "Delete snippet",
                "icon": "$(trash)"
            },
            {
                "command": "ib-utilities.terminalPaste",
                "title": "Terminal paste (text or image)",
                "shortTitle": "Terminal paste"
            },
            {
                "command": "ib-utilities.openMermaidPreview",
                "title": "Open Preview",
                "shortTitle": "Open Preview",
                "icon": "$(open-preview)"
            },
            {
                "command": "ib-utilities.openMermaidSource",
                "title": "Open Source",
                "shortTitle": "Open Source",
                "icon": "$(code)"
            },
            {
                "command": "ib-utilities.showGitHelpers",
                "title": "Show Git Helpers",
                "shortTitle": "Git Helpers",
                "icon": "$(git-branch)"
            },
            {
                "command": "ib-utilities.refreshGitHelpers",
                "title": "Refresh Git Helpers",
                "shortTitle": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "ib-utilities.showActionPanel",
                "title": "Show Action Panel",
                "shortTitle": "Actions",
                "icon": "$(run-all)"
            },
            {
                "command": "ib-utilities.runActionPanelItem",
                "title": "Run Action Panel Item",
                "icon": "$(run)"
            },
            {
                "command": "ib-utilities.addActionPanelAction",
                "title": "Add Action",
                "shortTitle": "Add action",
                "icon": "$(add)"
            },
            {
                "command": "ib-utilities.editActionPanelAction",
                "title": "Edit Action",
                "shortTitle": "Edit action",
                "icon": "$(edit)"
            },
            {
                "command": "ib-utilities.deleteActionPanelAction",
                "title": "Delete Action",
                "shortTitle": "Delete action",
                "icon": "$(trash)"
            },
            {
                "command": "ib-utilities.diffWithBase",
                "title": "Diff vs Base Branch",
                "shortTitle": "Diff vs base",
                "icon": "$(diff)"
            },
            {
                "command": "ib-utilities.setBaseBranch",
                "title": "Set Base Branch",
                "shortTitle": "Set base",
                "icon": "$(gear)"
            },
            {
                "command": "ib-utilities.addReviewNote",
                "title": "Add Review Note",
                "shortTitle": "Add note",
                "icon": "$(note)"
            },
            {
                "command": "ib-utilities.publishReviewToPR",
                "title": "Publish Review to PR",
                "shortTitle": "Publish to PR",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "ib-utilities.exportReviewSummary",
                "title": "Export Review Summary",
                "shortTitle": "Export summary",
                "icon": "$(export)"
            },
            {
                "command": "ib-utilities.reviewComment.create",
                "title": "Save",
                "enablement": "!commentIsEmpty"
            },
            {
                "command": "ib-utilities.reviewComment.save",
                "title": "Save"
            },
            {
                "command": "ib-utilities.reviewComment.cancel",
                "title": "Cancel"
            },
            {
                "command": "ib-utilities.reviewComment.delete",
                "title": "Delete",
                "icon": "$(trash)"
            },
            {
                "command": "ib-utilities.reviewComment.edit",
                "title": "Edit note",
                "icon": "$(edit)"
            },
            {
                "command": "ib-utilities.revertBranchDiffHunk",
                "title": "Revert Hunk to Base",
                "shortTitle": "Revert hunk",
                "icon": "$(discard)"
            },
            {
                "command": "ib-utilities.revertBranchDiffSelection",
                "title": "Revert Selection to Base",
                "shortTitle": "Revert selection",
                "icon": "$(discard)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "ib-utilities.openMermaidPreview",
                    "when": "(resourceExtname == .mmd || resourceExtname == .mermaid) && activeCustomEditorId != 'ib-utilities.mermaidPreview'",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.openMermaidSource",
                    "when": "activeCustomEditorId == 'ib-utilities.mermaidPreview'",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.addReviewNote",
                    "when": "resourceScheme == git || ib-utilities.inBranchDiffFile",
                    "group": "navigation@1"
                },
                {
                    "command": "ib-utilities.publishReviewToPR",
                    "when": "resourceScheme == git",
                    "group": "navigation@2"
                }
            ],
            "editor/context": [
                {
                    "command": "ib-utilities.revertBranchDiffSelection",
                    "when": "ib-utilities.inBranchDiffFile && editorHasSelection && inDiffEditor",
                    "group": "ib-utilities@0"
                },
                {
                    "command": "ib-utilities.revertBranchDiffHunk",
                    "when": "ib-utilities.inBranchDiffFile && !editorHasSelection && inDiffEditor",
                    "group": "ib-utilities@0"
                },
                {
                    "command": "ib-utilities.addReviewNote",
                    "when": "resourceScheme == git || ib-utilities.inBranchDiffFile",
                    "group": "ib-utilities@1"
                }
            ],
            "commandPalette": [
                {
                    "command": "ib-utilities.reviewComment.create",
                    "when": "false"
                },
                {
                    "command": "ib-utilities.reviewComment.save",
                    "when": "false"
                },
                {
                    "command": "ib-utilities.reviewComment.cancel",
                    "when": "false"
                },
                {
                    "command": "ib-utilities.reviewComment.delete",
                    "when": "false"
                }
            ],
            "comments/commentThread/title": [
                {
                    "command": "ib-utilities.reviewComment.delete",
                    "group": "navigation@2",
                    "when": "commentController == ib-utilities.review && !commentThreadIsEmpty"
                }
            ],
            "comments/commentThread/context": [
                {
                    "command": "ib-utilities.reviewComment.create",
                    "group": "inline",
                    "when": "commentController == ib-utilities.review && commentThreadIsEmpty"
                }
            ],
            "comments/comment/context": [
                {
                    "command": "ib-utilities.reviewComment.save",
                    "group": "inline@1",
                    "when": "commentController == ib-utilities.review && comment == editing"
                },
                {
                    "command": "ib-utilities.reviewComment.cancel",
                    "group": "inline@2",
                    "when": "commentController == ib-utilities.review && comment == editing"
                }
            ],
            "comments/comment/title": [
                {
                    "command": "ib-utilities.reviewComment.edit",
                    "group": "group@1",
                    "when": "commentController == ib-utilities.review && comment == note && commentThread != published"
                }
            ],
            "view/item/context": [
                {
                    "command": "ib-utilities.editSnippet",
                    "when": "view == snippetView && viewItem == folder",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.addSnippet",
                    "when": "view == snippetView && viewItem == folder",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.deleteSnippet",
                    "when": "view == snippetView && viewItem == file",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.editActionPanelAction",
                    "when": "view == ib-utilities.actionPanel && viewItem == action",
                    "group": "inline@1"
                },
                {
                    "command": "ib-utilities.deleteActionPanelAction",
                    "when": "view == ib-utilities.actionPanel && viewItem == action",
                    "group": "inline@2"
                },
                {
                    "command": "ib-utilities.setBaseBranch",
                    "when": "view == ib-utilities.gitHelpers && viewItem == action-diffWithBase",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.markPrReady",
                    "when": "view == ib-utilities.gitHelpers && viewItem == action-openPr-draft",
                    "group": "inline@1"
                },
                {
                    "command": "ib-utilities.copyPrUrl",
                    "when": "view == ib-utilities.gitHelpers && (viewItem == action-openPr || viewItem == action-openPr-draft)",
                    "group": "inline@2"
                }
            ],
            "view/title": [
                {
                    "command": "ib-utilities.showSnippetView",
                    "when": "view == snippetContainer",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.refreshSnippetView",
                    "when": "view == snippetView",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.openPR",
                    "when": "view == ib-utilities.gitHelpers",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.refreshGitHelpers",
                    "when": "view == ib-utilities.gitHelpers",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.addActionPanelAction",
                    "when": "view == ib-utilities.actionPanel",
                    "group": "navigation"
                }
            ]
        }
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.13.3",
        "@types/vscode": "^1.125.0",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@vitest/coverage-v8": "^4.1.10",
        "@vscode/vsce": "^3.9.2",
        "esbuild": "0.28.1",
        "eslint": "^9.39.5",
        "opentype.js": "^1.3.4",
        "ts-loader": "^9.6.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10",
        "webpack": "^5.108.4",
        "webpack-cli": "^7.2.1"
    },
    "dependencies": {
        "mermaid": "^11.16.0"
    }
}
