{
    "name": "ib-utilities",
    "displayName": "IrishBruse's Utilities",
    "description": "A collection of utilities made by me",
    "icon": "logo.png",
    "repository": {
        "url": "https://github.com/IrishBruse/irishbruse-utilities"
    },
    "publisher": "irishbruse",
    "author": "Ethan Conneely",
    "version": "0.10.0",
    "license": "MIT",
    "engines": {
        "vscode": "^1.110.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onView:ib-utilities.gitHelpers"
    ],
    "scripts": {
        "vscode:prepublish": "npm run package",
        "build": "node esbuild.mjs",
        "watch": "node esbuild.mjs --watch",
        "package": "node esbuild.mjs --production",
        "lint": "eslint src && tsc --noEmit",
        "test": "vitest run",
        "verify": "npm run build && npm run test && npm run lint",
        "package:vsix": "vsce package --out ib-utilities-$(node -p \"require('./package.json').version\").vsix",
        "release": "node scripts/release.mjs",
        "test:watch": "vitest watch",
        "generate:contributes": "tsx --experimental-transform-types generators/contributes.generator.ts",
        "generate:contributes:watch": "tsx --watch --experimental-transform-types generators/contributes.generator.ts"
    },
    "main": "./dist/extension.js",
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "IrishBruse Utilities",
            "properties": {
                "ib-utilities.languageIdMappings": {
                    "type": "object",
                    "description": "Map snippet files to known language ID.",
                    "additionalProperties": {
                        "type": "string",
                        "description": "The replacement language ID."
                    },
                    "default": {
                        "node": "typescript",
                        "react": "typescriptreact"
                    }
                },
                "ib-utilities.generatedLanguageMappings": {
                    "type": "object",
                    "description": "On the left is the languageId for the snippet to auto generate on the right is the comma delimited array of languages to build it from.",
                    "additionalProperties": {
                        "type": "string",
                        "description": "The resulting language ID."
                    },
                    "default": {
                        "javascript": "node",
                        "typescript": "node",
                        "typescriptreact": "node,react",
                        "javascriptreact": "node,react"
                    }
                }
            }
        },
        "customEditors": [
            {
                "viewType": "ib-utilities.mermaidPreview",
                "displayName": "Mermaid Preview",
                "selector": [
                    {
                        "filenamePattern": "*.mmd"
                    },
                    {
                        "filenamePattern": "*.mermaid"
                    }
                ],
                "priority": "default"
            }
        ],
        "languages": [
            {
                "id": "gherkin",
                "aliases": [
                    "Gherkin",
                    "feature",
                    "cucumber"
                ],
                "extensions": [
                    ".feature"
                ],
                "configuration": "./syntaxes/gherkin.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gherkin",
                "scopeName": "text.gherkin.feature",
                "path": "./syntaxes/gherkin.tmLanguage"
            },
            {
                "scopeName": "markdown.gherkin.codeblock",
                "path": "./syntaxes/gherkin.markdown-injection.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.gherkin": "gherkin"
                }
            }
        ],
        "themes": [
            {
                "label": "Empty Dark Theme",
                "uiTheme": "vs-dark",
                "path": "./themes/empty-dark.json"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "snippetContainer",
                    "title": "Snippet Manager",
                    "icon": "media/snippet_icon.svg"
                }
            ]
        },
        "views": {
            "snippetContainer": [
                {
                    "id": "snippetView",
                    "name": "Groups",
                    "icon": "media/snippet_icon.svg"
                }
            ],
            "scm": [
                {
                    "id": "ib-utilities.gitHelpers",
                    "name": "Git Helpers",
                    "icon": "$(git-branch)",
                    "contextualTitle": "Git Helpers",
                    "visibility": "visible"
                }
            ]
        },
        "commands": [
            {
                "command": "ib-utilities.relativeGoTo",
                "title": "Relative goto",
                "shortTitle": "Relative goto"
            },
            {
                "command": "ib-utilities.openSnippet",
                "title": "Open Snippet",
                "shortTitle": "Open"
            },
            {
                "command": "ib-utilities.showSnippetView",
                "title": "Show Snippet View",
                "shortTitle": "Show Snippet View"
            },
            {
                "command": "ib-utilities.openPR",
                "title": "Open Pull Request",
                "shortTitle": "Open PR",
                "icon": "$(github)"
            },
            {
                "command": "ib-utilities.refreshSnippetView",
                "title": "Refresh Snippets",
                "shortTitle": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "ib-utilities.addSnippet",
                "title": "Add new snippet",
                "shortTitle": "Add snippet",
                "icon": "$(add)"
            },
            {
                "command": "ib-utilities.editSnippet",
                "title": "Edit snippet",
                "shortTitle": "Edit snippet",
                "icon": "$(edit)"
            },
            {
                "command": "ib-utilities.deleteSnippet",
                "title": "Delete snippet",
                "shortTitle": "Delete snippet",
                "icon": "$(trash)"
            },
            {
                "command": "ib-utilities.openMermaidPreview",
                "title": "Open Preview",
                "shortTitle": "Open Preview",
                "icon": "$(open-preview)"
            },
            {
                "command": "ib-utilities.openMermaidSource",
                "title": "Open Source",
                "shortTitle": "Open Source",
                "icon": "$(code)"
            },
            {
                "command": "ib-utilities.refreshGitHelpers",
                "title": "Refresh Git Helpers",
                "shortTitle": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "ib-utilities.showGitHelpers",
                "title": "Show Git Helpers",
                "shortTitle": "Git Helpers",
                "icon": "$(git-branch)"
            },
            {
                "command": "ib-utilities.diffWithBase",
                "title": "Diff vs Base Branch",
                "shortTitle": "Diff vs base",
                "icon": "$(diff)"
            },
            {
                "command": "ib-utilities.startBranchReview",
                "title": "Start Branch Review",
                "shortTitle": "Start review",
                "icon": "$(eye)"
            },
            {
                "command": "ib-utilities.abortBranchReview",
                "title": "Abort Branch Review",
                "shortTitle": "Abort review",
                "icon": "$(discard)"
            },
            {
                "command": "ib-utilities.openStagedReview",
                "title": "Open Staged Review",
                "shortTitle": "Staged review",
                "icon": "$(list-flat)"
            },
            {
                "command": "ib-utilities.excludeFromReview",
                "title": "Exclude Selection from Review",
                "shortTitle": "Exclude from review",
                "icon": "$(diff-removed)"
            },
            {
                "command": "ib-utilities.addReviewNote",
                "title": "Add Review Note",
                "shortTitle": "Add note",
                "icon": "$(note)"
            },
            {
                "command": "ib-utilities.publishReviewToPR",
                "title": "Publish Review to PR",
                "shortTitle": "Publish to PR",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "ib-utilities.exportReviewSummary",
                "title": "Export Review Summary",
                "shortTitle": "Export summary",
                "icon": "$(export)"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "ib-utilities.openMermaidPreview",
                    "when": "(resourceExtname == .mmd || resourceExtname == .mermaid) && activeCustomEditorId != 'ib-utilities.mermaidPreview'",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.openMermaidSource",
                    "when": "activeCustomEditorId == 'ib-utilities.mermaidPreview'",
                    "group": "navigation"
                }
            ],
            "editor/context": [
                {
                    "command": "ib-utilities.excludeFromReview",
                    "when": "ib-utilities.inBranchReview",
                    "group": "ib-utilities@1"
                },
                {
                    "command": "ib-utilities.addReviewNote",
                    "when": "ib-utilities.inBranchReview",
                    "group": "ib-utilities@2"
                }
            ],
            "scm/title": [
                {
                    "command": "ib-utilities.showGitHelpers",
                    "when": "scmProvider == git",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.openPR",
                    "when": "scmProvider == git",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "ib-utilities.editSnippet",
                    "when": "view == snippetView && viewItem == folder",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.addSnippet",
                    "when": "view == snippetView && viewItem == folder",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.deleteSnippet",
                    "when": "view == snippetView && viewItem == file",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.diffWithBase",
                    "when": "view == ib-utilities.gitHelpers && viewItem == action-diffWithBase",
                    "group": "inline"
                },
                {
                    "command": "ib-utilities.startBranchReview",
                    "when": "view == ib-utilities.gitHelpers && viewItem == action-startReview",
                    "group": "inline"
                }
            ],
            "view/title": [
                {
                    "command": "ib-utilities.showSnippetView",
                    "when": "view == snippetContainer",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.refreshSnippetView",
                    "when": "view == snippetView",
                    "group": "navigation"
                },
                {
                    "command": "ib-utilities.refreshGitHelpers",
                    "when": "view == ib-utilities.gitHelpers",
                    "group": "navigation"
                }
            ]
        }
    },
    "devDependencies": {
        "@types/cjson": "^0.5.3",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.12.2",
        "@types/vscode": "^1.110.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitest/coverage-v8": "^4.1.0",
        "@vscode/vsce": "^3.3.2",
        "esbuild": "0.27.4",
        "eslint": "^9.39.4",
        "ts-loader": "^9.5.4",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.0",
        "webpack": "^5.105.4",
        "webpack-cli": "^7.0.2"
    },
    "dependencies": {
        "cjson": "^0.5.0",
        "mermaid": "^11.12.0"
    }
}
